  "Paging List Template": {
    "prefix": "qqq-----page",
    "body": [
      "<template>",
      "  <view>",
      "    <yy-paging",
      "      v-model=\"state.dataList\"",
      "      @query=\"queryList\"",
      "      ref=\"paging\"",
      "      :auto=\"false\"",
      "      @scroll=\"scroll\"",
      "      :refresher-enabled=\"true\"",
      "    >",
      "      <template #top>",
      "        <u-navbar",
      "          :background=\"{ backgroundColor: state.isScroll ? '#fff' : '#fff' }\"",
      "          :title=\"state.title\"",
      "          :border-bottom=\"false\"",
      "          title-color=\"#000\"",
      "          isBack",
      "          backIconColor=\"#000\"",
      "        >",
      "        </u-navbar>",
      "      </template>",
      "      <template #empty>",
      "        <yy-empty></yy-empty>",
      "      </template>",
      "      <template #loadingMoreNoMore>",
      "        <yy-nomore></yy-nomore>",
      "      </template>",
      "      <template #bottom>",
      "        <!-- <view class=\"h-11\"></view> -->",
      "      </template>",
      "      <view class=\"flex flex-col px-3\">",
      "        $0",
      "      </view>",
      "    </yy-paging>",
      "  </view>",
      "</template>",
      "",
      "<script setup>",
      "  const state = ref({",
      "    isScroll: false,",
      "    dataList: [],",
      "    title: '${1:页面标题}'",
      "  })",
      "",
      "  const paging = ref()",
      "",
      "  onLoad(options => {",
      "    console.log('🚀 页面加载:', options)",
      "  })",
      "",
      "  onShow(options => {",
      "    console.log('🚀 页面加载:', options)",
      "  })",
      "",
      "  const scroll = e => {",
      "    state.value.isScroll = e.detail.scrollTop > 0",
      "  }",
      "",
      "  const queryList = (page, limit) => {",
      "    setTimeout(() => {",
      "      paging.value?.complete([1])",
      "    }, 1000)",
      "  }",
      "</script>",
      "",
      "<style lang=\"scss\" scoped></style>"
    ],
    "description": "创建完整的分页列表页面模板"
  },

