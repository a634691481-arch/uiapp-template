  "Snapdom Screenshot Template": {
    "prefix": "qqq-----screenshot",
    "body": [
      "  const ${1:downloadScreenshot} = async () => {",
      "    try {",
      "      vk.showLoading('生成图片中...') ",
      "",
      "      const element = document.getElementById('${2:user-info-card}')",
      "      if (!element) {",
      "        throw new Error('未找到要截图的元素')",
      "      }",
      "",
      "      const { snapdom } = await import('https://unpkg.com/@zumer/snapdom/dist/snapdom.mjs')",
      "      const result = await snapdom(element, {",
      "        download: true,",
      "        filename: `${3:截图}_${Date.now()}.png`,",
      "        backgroundColor: '#fff'",
      "      })",
      "",
      "      await result.download()",
      "      vk.toast('下载成功')",
      "    } catch (error) {",
      "      vk.toast(error || '截图失败,请重试')",
      "    } finally {",
      "      vk.hideLoading()",
      "    }",
      "  }"
    ],
    "description": "使用 snapdom 动态截图下载功能"
  },
